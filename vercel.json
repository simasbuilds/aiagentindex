{
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/resources.html",
      "destination": "/resources/",
      "permanent": true
    },
    {
      "source": "/workshop-exercises",
      "destination": "/demo-1/",
      "permanent": true
    },
    {
      "source": "/workshop-exercises/:path*",
      "destination": "/demo-1/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
